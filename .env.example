# Oracle credentials
PCDS_USR=my_oracle_user
PCDS_PWD=my_oracle_password
PB23_PWD=my_pb23_password
DTRACK_ORACLE_MOCK=sample_data/oracle_mock
DTRACK_ATHENA_MOCK=sample_data/athena_mock

# LDAP base (optional — if set, Oracle DSN resolved via LDAP)
# LDAP_BASE=ldap://ldap.example.com:389
N_SAMPLE=100
SEED=2025

# AWS credentials (for gen-aws)
AWS_DEFAULT_REGION=us-east-1
AWS_USR=my_aws_user
AWS_PWD=my_aws_pwd
AWS_S3_WORK_GROUP=primary
AWS_S3_STAGING_DIR=s3://my-bucket/athena-output/

# SAS generation
EMAIL_TO=user@example.com
SAS_LIB=/path/to/sas/lib
OUT_DIR=/path/to/mps/folder

# Column extraction optimization
# Max columns per batch (prevents SQL length limits for large tables)
MAX_COLS_PER_BATCH=40
ORACLE_PARALLEL=3